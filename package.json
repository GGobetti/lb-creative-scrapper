{
  "name": "lb-creative-scrapper",
  "version": "1.0.0",
  "type": "module",
  "description": "CLI para escanear grupos Telegram e indexar STLs no LB Creative Studio",
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:scan": "tsx src/index.ts",
    "build": "next build",
    "start": "next start -p 3001",
    "scan": "tsx src/index.ts scan",
    "scan:48h": "tsx src/index.ts scan --hours 48",
    "scan-group": "tsx src/index.ts scan-group",
    "daemon": "tsx src/index.ts daemon --interval 30",
    "daemon:1h": "tsx src/index.ts daemon --interval 60",
    "backfill:r2": "tsx scripts/backfill-vault-to-r2.ts",
    "dedup:photos": "tsx scripts/dedup-photos.ts",
    "regen:telegram": "tsx scripts/regenerate-telegram-session.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-separator": "^1.1.10",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.39.0",
    "@tailwindcss/postcss": "^4.3.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "jimp": "^0.22.10",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-themes": "^0.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "telegram": "^2.19.10",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.24",
    "@vitejs/plugin-react": "^6.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vite": "^8.0.16"
  }
}
