# ─── Telegram (GramJS / MTProto) ───────────────────────────────
# Credenciais da API: https://my.telegram.org
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash
# String de sessão (gerada no primeiro login interativo: `npm run scan`)
TELEGRAM_SESSION=
# Canal privado "Vault" (formato -100...) — LEGADO, será aposentado com a migração para R2
TELEGRAM_VAULT_CHANNEL_ID=

# ─── Supabase (metadados / fila / índice) ──────────────────────
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Cloudflare R2 (arquitetura-alvo — ver ARCHITECTURE.md §6) ──
# Armazém-mestre + entrega dos STLs (substitui o Telegram Vault).
# Preencher quando a conta/bucket existirem (Fase 1A).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# NOTA: o limite de tamanho e a lista de grupos NÃO são lidos daqui —
# vêm da tabela `telegram_scraper_settings` no Supabase (size_limit_mb, groups_config).
